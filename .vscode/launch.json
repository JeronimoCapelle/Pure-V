{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Assembler",
            "cargo": {
                "args": [
                    "build",
                    "--bin=assembler",
                    "--package=assembler"
                ],
                "filter": {
                    "name": "pure-rv32i",
                    "kind": "bin"
                }
            },
            "args": ["input.txt"], 
            "cwd": "${workspaceFolder}"
        }
    ]
}